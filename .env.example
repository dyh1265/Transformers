# Copy to `.env` for docker compose / local tooling (never commit `.env`).

# Weights & Biases (optional). Used when training with --use-wandb.
# Get a key at https://wandb.ai/authorize
WANDB_API_KEY=

# Default JSON config path for library helpers (optional).
# Training CLI prefers --config; see nano_llm.config.load_config.
NANO_LLM_CONFIG=

# Docker / NVIDIA (optional; compose sets defaults for the train service)
# NVIDIA_VISIBLE_DEVICES=all
